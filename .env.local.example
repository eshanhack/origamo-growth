# Copy this file to .env.local and fill in your values
# (Never commit .env.local to git)

# ── Grafana Integration ────────────────────────────────────────────────────────
# Your Grafana instance URL (no trailing slash)
GRAFANA_URL=https://your-grafana.example.com

# API Key or Service Account token
# Grafana < 9:  Profile → API Keys → Create (Viewer role is enough)
# Grafana 9+:   Administration → Service Accounts → New Service Account
GRAFANA_API_KEY=glsa_xxxxxxxxxxxxxxxxxxxx

# Dashboard UID — find it in the URL when viewing your dashboard:
# https://grafana.example.com/d/<UID>/dashboard-name
GRAFANA_DASHBOARD_UID=AbCdEfGhIj

# ── Panel ID Mapping ──────────────────────────────────────────────────────────
# After setting the above, update GRAFANA_PANEL_IDS in lib/grafana.ts
# to match the panel IDs in your actual dashboard.
# To find a panel's ID: open the panel editor and check the URL for panelId=XX
